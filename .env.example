# Configuração exclusivamente para desenvolvimento local.
COMPOSE_PROJECT_NAME=limen

POSTGRES_DB=limen
POSTGRES_USER=limen
POSTGRES_PASSWORD=limen_dev_only
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=default
RQ_VIDEO_QUEUE_NAME=video
OUTBOX_RECONCILE_INTERVAL_SECONDS=5
# Timeouts por modalidade (segundos). ADR 0017.
# LIMEN_TIMEOUT_VITALS_SECONDS=30
# LIMEN_TIMEOUT_AUDIO_SECONDS=90
# LIMEN_TIMEOUT_VIDEO_SECONDS=180
# Retries transitórios (ADR 0015).
LIMEN_RETRY_MAX_ATTEMPTS=3
LIMEN_RETRY_BASE_DELAY_SECONDS=1
# Circuit breaker Azure (stub T5.8 / ADR 0015). Sem chamada real nesta fase.
AZURE_ENABLED=false
LIMEN_AZURE_CB_FAILURE_THRESHOLD=3
LIMEN_AZURE_CB_OPEN_SECONDS=300
# LIMEN_AZURE_CB_FORCE_OPEN=true
# Falha forçada de modalidade no worker (CSV: audio). Vazio = desligado. Só TDD/demo.
# LIMEN_FORCE_FAIL_MODALITIES=audio

MINIO_ACCESS_KEY=limen
MINIO_SECRET_KEY=limen_dev_only_secret
MINIO_BUCKET=limen
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

BACKEND_PORT=8000
FRONTEND_PORT=3000
# Origem FastAPI para o rewrite /api do Next (hostname do Compose).
# Fora do Compose (`npm run dev`): use http://localhost:8000
BACKEND_URL=http://backend:8000
HEALTH_CHECK_TIMEOUT_SECONDS=2

JWT_SECRET=dev-only-change-me-use-32chars-min
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
AUTH_LOGIN_RATE_LIMIT=5/minute

# Operadores seed: somente para desenvolvimento local e demo.
SEED_MEDICO_USERNAME=medico
SEED_MEDICO_PASSWORD=medico_dev_only
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin_dev_only

# Rótulo Sensível (Fernet). Somente local/demo — gere outra chave fora do exemplo:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=gdAerhnfjaGxbiMCFFrZqTCG2_Hjrpkx_xoDzKsFL3M=
